# Public site URL — used in metadata, sitemap, OG image. Vercel sets this automatically in production.
NEXT_PUBLIC_SITE_URL=https://dedhameducationfoundation.org

# Formspree endpoints for the two forms on the site. Replace REPLACE-ME after
# creating the forms at https://formspree.io. Both are public — they're meant
# to be bundled into the client.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/REPLACE-ME
NEXT_PUBLIC_FORMSPREE_MONTHLY=https://formspree.io/f/REPLACE-ME

# Google Analytics 4 measurement ID. Leave blank to disable GA4 tracking.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
